# Google Places API — para traer reseñas y rating automáticamente.
# Cómo conseguirla: Google Cloud Console > APIs & Services > Credentials
# (activa "Places API" y añade restricciones de la key por seguridad)
GOOGLE_PLACES_API_KEY=

# Resend — para el envío de emails del formulario de contacto.
# Cómo conseguirla: https://resend.com (plan gratuito disponible)
RESEND_API_KEY=

# Dirección "from" verificada en Resend (necesita dominio propio verificado
# para que los correos no caigan en spam). Ej: web@localflow.ie
CONTACT_FROM_EMAIL=
